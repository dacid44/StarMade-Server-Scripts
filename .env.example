# StarMade Server Configuration
# Copy this file to .env and edit the values before running install.sh or any script.
#
# Settings marked [Docker] are used by docker-compose.yml.
# Settings marked [Native] are used by the bash scripts on Linux.
# Settings marked [Both] apply to both setups.

# ---------------------------------------------------------------
# [Both] Server directory — absolute path on the host
# ---------------------------------------------------------------
STARMADE_DIR=/path/to/your/starmade/server

# ---------------------------------------------------------------
# [Both] Backup and log directories
# ---------------------------------------------------------------
BACKUP_DIR=${STARMADE_DIR}/backups
LOG_DIR=${STARMADE_DIR}/logs

# ---------------------------------------------------------------
# [Both] Update branch — "release", "dev", or "pre"
# ---------------------------------------------------------------
UPDATE_BRANCH=dev

# ---------------------------------------------------------------
# [Both] JVM heap settings
# ---------------------------------------------------------------
JVM_MIN_HEAP=4g
JVM_MAX_HEAP=8g

# [Both] Extra JVM arguments (space-separated)
# Required for the pre branch — leave empty for release/dev
# JVM_EXTRA_ARGS=--add-opens=java.base/jdk.internal.misc=ALL-UNNAMED
JVM_EXTRA_ARGS=

# ---------------------------------------------------------------
# [Both] Server mode - "tmux", "docker", or blank to autodetect
# ---------------------------------------------------------------
SERVER_MODE=

# ---------------------------------------------------------------
# [Docker] Image settings
# ---------------------------------------------------------------
# Java version for the Docker image — use 8 for release/dev, 25 for pre
JAVA_VERSION=8

# Port exposed on the host
SERVER_PORT=4242

# Container name - used to detect and send commands to the running server
CONTAINER_NAME=starmade

# ---------------------------------------------------------------
# [Native] Linux-only settings
# ---------------------------------------------------------------
# tmux session name
TMUX_SESSION=StarMade

# systemd service name (must match your .service unit file)
SYSTEMCTL_SERVICE=starmade

# Number of backup archives to keep before pruning the oldest
MAX_BACKUPS=3
